# Whoop OAuth2 credentials (from https://developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://your-app.vercel.app/api/whoop-auth

# Whoop webhook HMAC secret (from Whoop developer dashboard → Webhooks)
WHOOP_WEBHOOK_SECRET=

# Optional: shared secret to protect /api/whoop-sync from public calls
# Pass as X-Sync-Secret header or ?secret= query param
WHOOP_SYNC_SECRET=

# Cronometer (Gold account required)
CRONOMETER_USERNAME=
CRONOMETER_PASSWORD=
CRONOMETER_SYNC_SECRET=

# Supabase (anon/service key — needs INSERT/UPDATE on whoop_tokens and recovery)
SUPABASE_URL=https://wszumxewqxkggtevfubb.supabase.co
SUPABASE_KEY=
